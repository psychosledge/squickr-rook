{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022", "DOM"],
    "strict":           true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess":   true,
    "noUnusedLocals":             true,
    "noUnusedParameters":         true,
    "skipLibCheck":               true,
    "noEmit":                     true
  },
  "include": ["src"]
}
