{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "strict":           true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess":   true,
    "declaration":      true,
    "outDir":           "./dist",
    "rootDir":          "./src",
    "skipLibCheck":     true
  },
  "include": ["src"]
}
